# FinanceFlow environment variables — copy to .env and adjust
# DO NOT commit .env to version control

# Ollama LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# Database
DATABASE_URL=sqlite:///./data/financeflow.db

# Exfil capture server (local-only demo endpoint)
EXFIL_CAPTURE_HOST=localhost
EXFIL_CAPTURE_PORT=8099
EXFIL_CAPTURE_URL=http://localhost:8099/capture

# Agent settings
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true
