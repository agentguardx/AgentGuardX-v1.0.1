# AgentGuard-X TLS Proxy (mitmproxy-based)
# Phase 6: intercept, triage, block/allow outbound agent traffic.
# Runs as non-root. CA generated at runtime into /home/mitmproxy/.mitmproxy/ (volume-mounted).

FROM mitmproxy/mitmproxy:11.0.0

LABEL service="agentguard-proxy"
LABEL maintainer="agentguardx@gmail.com"

USER root

RUN pip install --no-cache-dir httpx==0.28.1

# Copy agentguard proxy module so the addon can import it
WORKDIR /app
COPY agentguard/ agentguard/

# Pre-create the CA directory owned by mitmproxy (UID 1000).
# Docker copies this into the named volume on first mount, so mitmdump
# can write its auto-generated CA cert without needing root or gosu.
RUN mkdir -p /home/mitmproxy/.mitmproxy \
    && chown -R mitmproxy:mitmproxy /home/mitmproxy \
    && chown -R 1000:1000 /app

# Bypass the base image's docker-entrypoint.sh which calls gosu for
# privilege-dropping — gosu's setuid() is blocked by Docker Desktop's
# default seccomp profile on Windows/WSL2.  Run mitmdump directly.
ENTRYPOINT []
USER mitmproxy

ENV PYTHONPATH=/app
ENV MITMPROXY_OPTIONS=""

EXPOSE 8082

CMD ["mitmdump", \
     "--listen-host", "0.0.0.0", \
     "--listen-port", "8082", \
     "--mode", "regular", \
     "--set", "ssl_insecure=false", \
     "--set", "upstream_cert=true", \
     "-s", "/app/agentguard/proxy/addon.py"]
