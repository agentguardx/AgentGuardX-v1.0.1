# AgentGuard-X Sandbox Worker Image
# Single-use ephemeral container for sandboxed tool execution.
# Built on the FinanceFlow runtime so it can run the same tools.
# Network mode: none (isolated by manager at runtime).
# Non-root. Read-only filesystem option depends on tier.

FROM python:3.12-slim AS builder

WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc build-essential \
    && rm -rf /var/lib/apt/lists/*

# Only FinanceFlow runtime deps needed in the sandbox
COPY ../financeflow/requirements.txt ./financeflow-requirements.txt
RUN pip install --no-cache-dir --upgrade pip==24.3.1 \
    && pip install --no-cache-dir -r financeflow-requirements.txt --target /install

FROM python:3.12-slim

LABEL service="agentguard-sandbox-worker"
LABEL maintainer="agentguardx@gmail.com"

RUN groupadd --gid 1001 sandbox \
    && useradd --uid 1001 --gid sandbox --no-create-home --shell /bin/sh sandbox

COPY --from=builder /install /usr/local/lib/python3.12/site-packages

WORKDIR /sandbox

# Copy the sandbox tool runner entrypoint
COPY docker/sandbox_run_tool.py /sandbox/run_tool.py

# Copy financeflow tools so they can be executed in the sandbox
COPY ../financeflow/ /sandbox/financeflow/

RUN chown -R sandbox:sandbox /sandbox

USER sandbox

ENV PYTHONPATH=/sandbox
ENV PYTHONUNBUFFERED=1
ENV SANDBOX_MODE=1
# Prevent any outbound network calls even if network isolation is misconfigured
ENV NO_PROXY="*"
ENV HTTP_PROXY=""
ENV HTTPS_PROXY=""

# The container is kept alive by the pool using: docker run ... cat
# Actual execution happens via docker exec
CMD ["cat"]
