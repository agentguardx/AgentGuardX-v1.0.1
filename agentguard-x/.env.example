# AgentGuard-X environment variables — copy to .env and fill in values
# DO NOT commit .env

# ── Toggle ────────────────────────────────────────────────────────────────────
AGENTGUARD_ENFORCEMENT=true   # true=enforce, false=observe-only

# ── Sandbox ───────────────────────────────────────────────────────────────────
AGENTGUARD_SANDBOX_MODE=docker_only   # docker_only | gvisor (auto-detected by preflight)
DOCKER_HOST=unix:///var/run/docker.sock

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=3600

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8888
CHROMA_COLLECTION=agentguard_kb

# ── OPA ──────────────────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181
OPA_BUNDLE_PATH=/policies

# ── Triage engine ─────────────────────────────────────────────────────────────
TRIAGE_HOST=0.0.0.0
TRIAGE_PORT=8081
STAGE4_EMBED_TIMEOUT_SECONDS=5.0

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60
GATEWAY_RATE_LIMIT_MAX_CALLS=100

# ── TLS Proxy ────────────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8082
PROXY_CA_CERT=certs/ca.pem       # generated by agentguard.sh up, never committed
PROXY_CA_KEY=certs/ca.key        # generated by agentguard.sh up, never committed

# ── Analyst queue ──────────────────────────────────────────────────────────────
ANALYST_QUEUE_HOST=0.0.0.0
ANALYST_QUEUE_PORT=8083
HOLD_TIMEOUT_SECONDS=300         # 5-minute timeout; block on expiry (fail-closed)

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_PUSHGATEWAY_URL=http://localhost:9091

# ── Cheap-gate threshold (irreversible ops) ────────────────────────────────────
CHEAP_GATE_AUTO_ALLOW_THRESHOLD=100.0    # USD — below this, auto-allow trivially safe
CHEAP_GATE_AUTO_BLOCK_THRESHOLD=1000000.0  # USD — above this, auto-block egregious
